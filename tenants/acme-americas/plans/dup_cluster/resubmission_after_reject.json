{
  "plan_id": "resubmission_after_reject",
  "version": 1,
  "case_type": "dup_cluster",
  "tenant": "acme-americas",
  "signature": {
    "case_type": "dup_cluster",
    "match_fields": [
      "vendor",
      "invoice_number",
      "amount"
    ],
    "diff_fields": [
      "document_date"
    ],
    "po_kind": "standard"
  },
  "steps": [
    {
      "id": "fetch_pair",
      "skill": "spine.fetch_invoice_pair",
      "args": {
        "pair_id": "case_file.pair_id"
      },
      "expects": [
        "outputs.pair_found == true"
      ]
    },
    {
      "id": "check_prior",
      "skill": "spine.fetch_case_history",
      "args": {
        "invoice_number": "case_file.invoice_number"
      },
      "expects": [
        "outputs.prior_rejection_found == true"
      ]
    },
    {
      "id": "block_resubmission",
      "skill": "cases.record_disposition",
      "args": {
        "disposition": "confirmed_duplicate"
      },
      "gates": [
        "duplicate_disposition_check"
      ],
      "approval": true
    }
  ],
  "on_expectation_failure": "escalate",
  "citations": [
    "ACME-AP-POL-114 v2 \u00a74.2",
    "ACME-AP-POL-114 v2 \u00a74.3"
  ]
}
