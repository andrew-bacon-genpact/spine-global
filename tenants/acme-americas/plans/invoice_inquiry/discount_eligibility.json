{
  "plan_id": "discount_eligibility",
  "version": 2,
  "case_type": "invoice.inquiry",
  "tenant": "acme-americas",
  "signature": {
    "case_type": "invoice.inquiry",
    "match_fields": [
      "vendor",
      "invoice_number"
    ],
    "intent": "discount"
  },
  "steps": [
    {
      "id": "fetch_invoice",
      "skill": "spine.fetch_invoice",
      "args": {
        "vendor_id": "case_file.vendor_id",
        "invoice_number": "case_file.invoice_number"
      },
      "expects": [
        "outputs.invoice_found == true"
      ]
    },
    {
      "id": "evaluate_discount",
      "skill": "custom.discount_npv_check",
      "args": {
        "invoice": "steps.fetch_invoice.invoice",
        "terms": "case_file.terms"
      },
      "expects": [
        "outputs.evaluated == true"
      ]
    },
    {
      "id": "compose_reply",
      "skill": "cases.compose_reply",
      "args": {
        "template": "discount_eligibility",
        "result": "steps.evaluate_discount.result"
      },
      "gates": [
        "reply_grounding_check"
      ],
      "approval": false
    }
  ],
  "on_expectation_failure": "escalate",
  "citations": [
    "ACME-AP-POL-102 \u00a73"
  ]
}
